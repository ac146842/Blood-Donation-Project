@model IEnumerable<Blood_Donation_Project.Models.MedicalForm>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Donor_ID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nurse_ID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FormDate)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Donor_ID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nurse_ID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FormDate)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Form_ID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Form_ID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Form_ID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
