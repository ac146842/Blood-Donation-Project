@model IEnumerable<Blood_Donation_Project.Models.FormAnswers>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Form_ID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HealthQ_ID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Answer)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Form_ID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HealthQ_ID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Answer)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Answers_ID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Answers_ID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Answers_ID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
